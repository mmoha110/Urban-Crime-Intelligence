.venv/
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.DS_Store

# Pipeline run logs (re-generated on every run)
pipeline_run.log

# Course write-ups and deck materials (local only; not pushed to GitHub)
reports/CS483_Final_Report.md
reports/final_report.md
reports/presentation_script.md
reports/slides_outline.md
reports/*.pdf
reports/*.pptx
outputs/reports/progress_report.md

# Data artifacts (too large and easily re-downloaded)
data/raw/*.csv
data/processed/*.csv
data/samples/*.csv

# Model binaries (too large; regenerated by running the pipeline)
outputs/models/*.joblib

# Generated figures and reports are intentionally tracked so the final
# report PDF can embed them without requiring a pipeline re-run.
!outputs/figures/.gitkeep
!outputs/models/.gitkeep
